{
  "name": "mememanager-ui",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "next dev",
    "dev:server": "npm run build:server && node dist-server/server/main.js",
    "build": "next build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "concurrently \"npm:start:web\" \"npm:start:server\"",
    "start:web": "next start",
    "start:server": "node dist-server/server/main.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "geist": "^1.7.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3"
  }
}
